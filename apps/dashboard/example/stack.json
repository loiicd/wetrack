{
  "key": "main-stack",
  "environment": "PRODUCTION",
  "dashboards": [
    {
      "key": "open-emergency-data-dashboard",
      "label": "Open Emergency Data Dashboard"
    },
    {
      "key": "user-activity-dashboard",
      "label": "User Activity Dashboard"
    }
  ],
  "dataSources": [
    {
      "key": "jsonplaceholder-posts",
      "type": "rest",
      "config": {
        "url": "https://jsonplaceholder.typicode.com/posts",
        "method": "get"
      }
    }
  ],
  "charts": [
    {
      "key": "posts-id-bar-chart",
      "dashboard": "open-emergency-data-dashboard",
      "query": "posts-top-10-query",
      "label": "Top 10 Posts (ID)",
      "description": "ID pro Post-Titel aus der Query.",
      "type": "bar",
      "config": {
        "categoryField": "title",
        "valueField": "id"
      },
      "layout": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 3
      }
    }
  ],
  "queries": [
    {
      "key": "posts-top-10-query",
      "dataSource": "jsonplaceholder-posts",
      "jsonPath": "$[0:10]"
    }
  ]
}
