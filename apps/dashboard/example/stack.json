{
  "key": "main-stack",
  "environment": "PRODUCTION",
  "dashboards": [
    {
      "key": "open-emergency-data-dashboard",
      "label": "Open Emergency Data Dashboard"
    },
    {
      "key": "user-activity-dashboard",
      "label": "User Activity Dashboard"
    }
  ],
  "dataSources": [
    {
      "key": "jsonplaceholder-posts",
      "type": "rest",
      "config": {
        "url": "https://jsonplaceholder.typicode.com/posts",
        "method": "get"
      }
    }
  ],
  "charts": [
    {
      "key": "posts-chart",
      "dataSource": "jsonplaceholder-posts"
    }
  ],
  "queries": [
    {
      "key": "posts-user-id-query",
      "dataSource": "jsonplaceholder-posts",
      "jsonPath": "$[*].userId"
    }
  ],
  "transforms": [
    {
      "key": "posts-per-user-transform",
      "query": "posts-user-id-query",
      "function": "GROUP_BY",
      "field": "userId",
      "groupByField": "userId"
    }
  ]
}
