{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "migrate": "[ -z \"$DATABASE_URL$POSTGRES_PRISMA_URL$POSTGRES_URL\" ] && echo 'Skipping migrate: no database URL configured' || prisma migrate deploy",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:dbpush": "prisma db push",
    "generate:timezone-types": "bun run scripts/generate-timezone-types.ts",
    "cy:open": "cypress open --component",
    "cy:run": "cypress run --component"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "7.2.4",
    "@clerk/ui": "^1.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@number-flow/react": "^0.6.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@tanstack/react-table": "^8.21.3",
    "alasql": "^4.17.0",
    "axios": "1.15.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "fuse.js": "^7.3.0",
    "input-otp": "^1.4.2",
    "jsonpath-plus": "^10.4.0",
    "lucide-react": "0.577.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "node-sql-parser": "^5.4.0",
    "nuqs": "^2.8.9",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.9.0",
    "recharts": "3.8.0",
    "shadcn": "4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "tzdata": "^1.0.48",
    "vaul": "^1.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4",
    "@types/node": "20",
    "@types/pg": "8.18.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitest/coverage-v8": "^4.1.2",
    "cypress": "^15.13.0",
    "eslint": "9",
    "eslint-config-next": "16.1.6",
    "prisma": "7.4.2",
    "tailwindcss": "4",
    "typescript": "5",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
