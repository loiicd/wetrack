generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Environment {
  PRODUCTION
  STAGING
  DEVELOPMENT
}

enum TransformFunction {
  SUM
  AVG
  GROUP_BY
}

enum ChartType {
  BAR
  LINE
  STAT
  CLOCK
}

enum QueryType {
  JSONPATH
  SQL
}

model Stack {
  id          String      @id @default(uuid())
  key         String
  version     Int         @default(1)
  environment Environment
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  dashboards  Dashboard[]
  dataSources DataSource[]
  charts      Chart[]
  queries     Query[]
  transforms  Transform[]
  credentials Credential[]

  @@unique([key, environment])
}

model Dashboard {
  id          String   @id @default(uuid())
  key         String
  version     Int      @default(1)
  stackId     String
  label       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stack  Stack   @relation(fields: [stackId], references: [id])
  charts Chart[]

  @@unique([stackId, key])
}

model DataSource {
  id        String   @id @default(uuid())
  key       String
  version   Int      @default(1)
  stackId   String
  type      String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack   Stack   @relation(fields: [stackId], references: [id])
  queries Query[]

  @@unique([stackId, key])
}

model Chart {
  id          String    @id @default(uuid())
  key         String
  version     Int       @default(1)
  stackId     String
  dashboardId String
  queryId     String?
  type        ChartType
  label       String
  description String?
  config      Json
  layoutX     Int       @default(0)
  layoutY     Int       @default(0)
  layoutW     Int       @default(6)
  layoutH     Int       @default(3)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stack     Stack     @relation(fields: [stackId], references: [id])
  dashboard Dashboard @relation(fields: [dashboardId], references: [id])
  query     Query?    @relation(fields: [queryId], references: [id])

  @@unique([stackId, key])
}

model Query {
  id            String    @id @default(uuid())
  key           String
  version       Int       @default(1)
  stackId       String
  type          QueryType @default(JSONPATH)
  dataSourceId  String?
  sourceQueryId String?
  jsonPath      String?
  sql           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stack          Stack       @relation(fields: [stackId], references: [id])
  dataSource     DataSource? @relation(fields: [dataSourceId], references: [id])
  sourceQuery    Query?      @relation("QuerySource", fields: [sourceQueryId], references: [id])
  derivedQueries Query[]     @relation("QuerySource")
  charts         Chart[]
  transforms     Transform[]

  @@unique([stackId, key])
}

model Transform {
  id           String            @id @default(uuid())
  key          String
  version      Int               @default(1)
  stackId      String
  queryId      String
  function     TransformFunction
  field        String
  groupByField String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  stack Stack @relation(fields: [stackId], references: [id])
  query Query @relation(fields: [queryId], references: [id])
}

model Credential {
  id        String   @id @default(uuid())
  key       String
  version   Int      @default(1)
  stackId   String
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack Stack @relation(fields: [stackId], references: [id])
}
