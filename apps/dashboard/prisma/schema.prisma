generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Environment {
  PRODUCTION
  STAGING
  DEVELOPMENT
}

enum Status {
  ACTIVE
  BUILDING
  INACTIVE
}

enum TransformFunction {
  SUM
  AVG
  GROUP_BY
}

model Stack {
  id          String      @id @default(uuid())
  key         String
  status      Status
  environment Environment
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  dashboards  Dashboard[]
  dataSources DataSource[]
  charts      Chart[]
  queries     Query[]
  transforms  Transform[]
  credentials Credential[]
}

model Dashboard {
  id        String   @id @default(uuid())
  key       String
  stackId   String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack Stack @relation(fields: [stackId], references: [id])

  @@index([stackId, key])
}

model DataSource {
  id        String   @id @default(uuid())
  key       String
  stackId   String
  type      String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack   Stack   @relation(fields: [stackId], references: [id])
  charts  Chart[]
  queries Query[]
}

model Chart {
  id           String   @id @default(uuid())
  key          String
  stackId      String
  dataSourceId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stack      Stack      @relation(fields: [stackId], references: [id])
  dataSource DataSource @relation(fields: [dataSourceId], references: [id])
}

model Query {
  id           String   @id @default(uuid())
  key          String
  stackId      String
  dataSourceId String
  jsonPath     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stack      Stack       @relation(fields: [stackId], references: [id])
  dataSource DataSource  @relation(fields: [dataSourceId], references: [id])
  transforms Transform[]
}

model Transform {
  id           String            @id @default(uuid())
  key          String
  stackId      String
  queryId      String
  function     TransformFunction
  field        String
  groupByField String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  stack Stack @relation(fields: [stackId], references: [id])
  query Query @relation(fields: [queryId], references: [id])
}

model Credential {
  id        String   @id @default(uuid())
  key       String
  stackId   String
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack Stack @relation(fields: [stackId], references: [id])
}
