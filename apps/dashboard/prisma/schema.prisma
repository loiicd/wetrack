generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Environment {
  PRODUCTION
  STAGING
  DEVELOPMENT
}

model Stack {
  id          String      @id @default(uuid())
  key         String
  environment Environment
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  dashboards  Dashboard[]
  dataSources DataSource[]
  charts      Chart[]
  credentials Credential[]
}

model Dashboard {
  id        String   @id @default(uuid())
  key       String
  stackId   String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack Stack @relation(fields: [stackId], references: [id])

  @@index([stackId, key])
}

model DataSource {
  id        String   @id @default(uuid())
  key       String
  stackId   String
  type      String
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack  Stack   @relation(fields: [stackId], references: [id])
  charts Chart[]
}

model Chart {
  id           String   @id @default(uuid())
  key          String
  stackId      String
  dataSourceId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stack      Stack      @relation(fields: [stackId], references: [id])
  dataSource DataSource @relation(fields: [dataSourceId], references: [id])
}

model Credential {
  id        String   @id @default(uuid())
  key       String
  stackId   String
  secret    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stack Stack @relation(fields: [stackId], references: [id])
}
