{
  "name": "@wetrack/cli",
  "version": "0.1.0",
  "description": "WeTrack Dashboard-as-Code CLI",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "wetrack": "./src/index.ts"
  },
  "scripts": {
