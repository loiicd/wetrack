{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "migrate": {
      "cache": false,
      "env": ["DATABASE_URL", "DATABASE_URL_UNPOOLED", "POSTGRES_*"]
    },
    "build": {
      "dependsOn": ["^build", "migrate"],
      "env": [
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "POSTGRES_*",
        "PG*",
        "NEON_PROJECT_ID",
        "CLERK_SECRET_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
